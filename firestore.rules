rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function friendshipAccepted(chatId) {
      return signedIn()
             && chatId is string
             && exists(/databases/$(database)/documents/friendships/$(chatId))
             && get(/databases/$(database)/documents/friendships/$(chatId)).data.status == 'accepted'
             && request.auth.uid in get(/databases/$(database)/documents/friendships/$(chatId)).data.userUids;
    }

    function isGlobalMessage(data) {
      return data.chatId == 'global';
    }

    function isGroupMessage(data) {
      return data.chatId is string && data.chatId.matches('^group_.*$');
    }

    function canAccessGroupMessage(data) {
      return isGroupMessage(data)
             && (
               !data.keys().hasAll(['groupId'])
               || (
                 data.groupId is string
                 && exists(/databases/$(database)/documents/groups/$(data.groupId))
                 && request.auth.uid in get(/databases/$(database)/documents/groups/$(data.groupId)).data.memberUids
               )
             );
    }

    function canAccessMessage(data) {
      return signedIn()
             && (
               isGlobalMessage(data)
               || canAccessGroupMessage(data)
               || friendshipAccepted(data.chatId)
             );
    }

    function onlyAddsReadReceipt() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
             && request.resource.data.readBy is list
             && request.auth.uid in request.resource.data.readBy
             && (
               !resource.data.keys().hasAll(['readBy'])
               || request.resource.data.readBy.hasAll(resource.data.readBy)
             );
    }

    function hasRelationshipWith(userId) {
      return signedIn()
             && userId is string
             && (
               exists(/databases/$(database)/documents/friendships/$(request.auth.uid + '_' + userId))
               || exists(/databases/$(database)/documents/friendships/$(userId + '_' + request.auth.uid))
             );
    }

    match /users/{userId} {
      allow get: if signedIn()
                 && (request.auth.uid == userId || hasRelationshipWith(userId));
      allow list: if false;
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /email_lookup/{emailKey} {
      // Exact document lookup only; listing/querying the collection is denied.
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn()
                    && request.auth.token.email is string
                    && emailKey == request.auth.token.email
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.email == request.auth.token.email;
      allow update: if signedIn()
                    && request.auth.token.email is string
                    && emailKey == request.auth.token.email
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.email == request.auth.token.email;
      allow delete: if signedIn()
                    && request.auth.token.email is string
                    && emailKey == request.auth.token.email
                    && resource.data.uid == request.auth.uid;
    }

    match /friendships/{friendshipId} {
      allow read: if signedIn() && request.auth.uid in resource.data.userUids;

      allow create: if signedIn()
                    && request.resource.data.status == 'pending'
                    && request.resource.data.requesterUid == request.auth.uid
                    && request.resource.data.userUids is list
                    && request.resource.data.userUids.size() == 2
                    && request.auth.uid in request.resource.data.userUids
                    && request.resource.data.addresseeUid in request.resource.data.userUids
                    && request.resource.data.requesterUid != request.resource.data.addresseeUid
                    && friendshipId == request.resource.data.userUids[0] + '_' + request.resource.data.userUids[1];

      allow update: if signedIn()
                    && request.auth.uid == resource.data.addresseeUid
                    && request.auth.uid in resource.data.userUids
                    && resource.data.status == 'pending'
                    && request.resource.data.status == 'accepted'
                    && request.resource.data.userUids == resource.data.userUids
                    && request.resource.data.requesterUid == resource.data.requesterUid
                    && request.resource.data.addresseeUid == resource.data.addresseeUid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt', 'updatedAt']);

      allow delete: if signedIn() && request.auth.uid in resource.data.userUids;
    }

    match /groups/{groupId} {
      allow create: if signedIn()
                    && request.resource.data.createdBy == request.auth.uid
                    && request.auth.uid in request.resource.data.memberUids;

      allow read: if signedIn()
                  && request.auth.uid in resource.data.memberUids;

      allow update, delete: if signedIn()
                            && resource.data.createdBy == request.auth.uid;
    }

    match /messages/{messageId} {
      allow read: if canAccessMessage(resource.data);

      allow create: if canAccessMessage(request.resource.data)
                    && request.resource.data.uid == request.auth.uid;

      allow update: if canAccessMessage(resource.data)
                    && (
                      resource.data.uid == request.auth.uid
                      || onlyAddsReadReceipt()
                    );

      allow delete: if canAccessMessage(resource.data)
                    && resource.data.uid == request.auth.uid;
    }
  }
}
